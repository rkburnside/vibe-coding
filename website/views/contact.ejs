<%- include('header', { title: 'Contact' }) %>
<%- include('nav', { section: 'contact' }) %>

<main class="main-content">
    <!-- Page Header -->
    <div class="page-header">
        <h1>Get In Touch</h1>
        <p>Let's discuss how we can work together</p>
    </div>

    <!-- Contact Section -->
    <section class="contact-section">
        <div class="container">
            <div class="contact-grid">
                <!-- Contact Info -->
                <div class="contact-info">
                    <h2>Contact Information</h2>
                    
                    <div class="contact-item">
                        <i class="fas fa-envelope"></i>
                        <div>
                            <h3>Email</h3>
                            <a href="mailto:<%= data.email %>"><%= data.email %></a>
                        </div>
                    </div>

                    <div class="contact-item">
                        <i class="fas fa-phone"></i>
                        <div>
                            <h3>Phone</h3>
                            <a href="tel:<%= data.phone %>"><%= data.phone %></a>
                        </div>
                    </div>

                    <div class="contact-item">
                        <i class="fas fa-map-marker-alt"></i>
                        <div>
                            <h3>Location</h3>
                            <p><%= data.location %></p>
                        </div>
                    </div>

                    <div class="contact-item">
                        <i class="fab fa-linkedin"></i>
                        <div>
                            <h3>LinkedIn</h3>
                            <a href="https://www.linkedin.com/in/<%= data.linkedin %>" target="_blank">Visit Profile</a>
                        </div>
                    </div>

                    <!-- Response Time -->
                    <div class="info-box">
                        <h3>Response Time</h3>
                        <p>I typically respond to inquiries within 24-48 hours.</p>
                    </div>
                </div>

                <!-- Contact Form -->
                <div class="contact-form-wrapper">
                    <h2>Send a Message</h2>
                    <form class="contact-form" method="POST" action="/contact">
                        <div class="form-group">
                            <label for="name">Name *</label>
                            <input type="text" id="name" name="name" required>
                        </div>

                        <div class="form-group">
                            <label for="email">Email *</label>
                            <input type="email" id="email" name="email" required>
                        </div>

                        <div class="form-group">
                            <label for="phone">Phone</label>
                            <input type="tel" id="phone" name="phone">
                        </div>

                        <div class="form-group">
                            <label for="subject">Subject *</label>
                            <input type="text" id="subject" name="subject" required>
                        </div>

                        <div class="form-group">
                            <label for="message">Message *</label>
                            <textarea id="message" name="message" rows="5" required></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary">Send Message</button>
                    </form>

                    <% if (typeof req !== 'undefined' && req.query.message) { %>
                        <div class="success-message">
                            <i class="fas fa-check-circle"></i>
                            <%= req.query.message %>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container cta-content">
            <h2>Let's Create Something Great Together</h2>
            <p>I'm open to discussing new opportunities, challenges, and collaborations.</p>
        </div>
    </section>
</main>

<%- include('footer') %>
